# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================

# Your Supabase instance URL
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-instance.com

# Supabase anonymous key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# =============================================================================
# PROJECT CONFIGURATION
# =============================================================================

# Project slug (must match the slug in public.projects table)
NEXT_PUBLIC_PROJECT_SLUG=my_project

# Project display name
NEXT_PUBLIC_PROJECT_NAME=My Project

# Database schema for this project (usually same as project_slug)
NEXT_PUBLIC_SUPABASE_SCHEMA=my_project

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================

# App URL (for OAuth redirects, emails, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Enable debug mode
# NEXT_PUBLIC_DEBUG=true
